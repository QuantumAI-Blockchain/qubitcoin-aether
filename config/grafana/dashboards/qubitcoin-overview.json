      "title": "Phi History",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "qbc_agi_phi_current",
          "legendFormat": "Phi (Consciousness)",
          "refId": "A"
        },
        {
          "expr": "3.0",
          "legendFormat": "Threshold",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 5, "lineWidth": 2 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Threshold" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#ef4444", "mode": "fixed" } },
              { "id": "custom.lineStyle", "value": { "dash": [10, 10], "fill": "dash" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Phi (Consciousness)" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#00ff88", "mode": "fixed" } }
            ]
          }
        ]
      }
    },
    {
      "title": "Network: Peers & Messages",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "qbc_active_peers",
          "legendFormat": "Active Peers",
          "refId": "A"
        },
        {
          "expr": "rate(qbc_messages_sent_total[5m])",
          "legendFormat": "Msgs Sent/s",
          "refId": "B"
        },
        {
          "expr": "rate(qbc_messages_received_total[5m])",
          "legendFormat": "Msgs Recv/s",
          "refId": "C"
        }
      ]
