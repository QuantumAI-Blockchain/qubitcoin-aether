# ==================================
# Qubitcoin .gitignore
# ==================================

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/
.pytest_cache/
venv/
env/

# ---- Rust ----
rust-p2p/target/
rust-p2p/Cargo.lock

# ---- Node / Frontend ----
frontend/node_modules/
frontend/.next/
frontend/.vercel/

# ---- Environment & Secrets ----
.env
*.env
!.env.example
!secure_key.env.example
secure_key.env

# ---- Private Keys & Certificates ----
*.pem
*.key
private_keys/
certs/

# ---- Data & Storage ----
data/
cockroach-data/
docker/cockroach-data/
.ipfs/

# ---- Logs ----
*.log
logs/
src/logs/
src/qubitcoin/logs/
frontend/logs/
tests/validation/*.log

# ---- Backup & Patch Files ----
*.backup
*.broken
*.patch
*.old

# ---- Build Artifacts ----
*.pid
*.tmp

# ---- Directories That Should Stay Deleted ----
archive/
backups/
monitoring/
migrations/
my-safe-directory/
contracts/

# ---- IDE ----
.vscode/
.idea/
*.swp
*.swo

# ---- OS ----
.DS_Store
Thumbs.db

# ---- Claude Code ----
.claude/worktrees/
