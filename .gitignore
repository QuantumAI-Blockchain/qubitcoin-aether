# ==================================
# Qubitcoin .gitignore
# ==================================

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/
.pytest_cache/
venv/
env/

# ---- Rust ----
rust-p2p/target/
rust-p2p/Cargo.lock
aikgs-sidecar/target/
substrate-node/target/
aether-core/target/
security-core/target/
security-core/Cargo.lock
stratum-server/target/
stratum-server/Cargo.lock
indexer/target/
api-gateway/target/

# ---- Node / Frontend ----
frontend/node_modules/
frontend/.next/
frontend/.vercel/

# ---- Environment & Secrets ----
.env
*.env
!.env.example
!secure_key.env.example
secure_key.env

# ---- Private Keys & Certificates ----
*.pem
*.key
private_keys/
secure_keys/
certs/
substrate-node/keys/
MNEMONIC_BACKUP*
OPERATIONS_GUIDE*

# ---- Data & Storage ----
data/
cockroach-data/
docker/cockroach-data/
.ipfs/

# ---- Logs ----
*.log
logs/
src/logs/
src/qubitcoin/logs/
frontend/logs/
tests/validation/*.log

# ---- Backup & Patch Files ----
*.backup
*.broken
*.patch
*.old

# ---- Build Artifacts ----
*.pid
*.tmp
frontend/storybook-static/

# ---- Directories That Should Stay Deleted ----
archive/
backups/
monitoring/
migrations/
my-safe-directory/
/contracts/

# ---- IDE ----
.vscode/
.idea/
*.swp
*.swo

# ---- OS ----
.DS_Store
Thumbs.db

# ---- Claude Code ----
.claude/worktrees/
