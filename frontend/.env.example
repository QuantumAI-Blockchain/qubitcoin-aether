# Qubitcoin Frontend Environment Configuration
# Copy to .env.local and edit for your setup
#
# Local development: defaults below work with docker-compose backend
# Production: set NEXT_PUBLIC_RPC_URL to your node's public endpoint

NEXT_PUBLIC_RPC_URL=http://localhost:5000
NEXT_PUBLIC_WS_URL=ws://localhost:5000/ws
NEXT_PUBLIC_CHAIN_ID=3301
NEXT_PUBLIC_CHAIN_NAME=Qubitcoin
NEXT_PUBLIC_CHAIN_SYMBOL=QBC
