    "d3": "^7.9.0",
    "ethers": "^6.16.0",
    "framer-motion": "^12.34.0",
    "lightweight-charts": "^5.1.0",
    "lucide-react": "^0.575.0",
    "next": "^16.1.6",
    "next-intl": "^4.8.3",
    "postcss": "^8.5.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
