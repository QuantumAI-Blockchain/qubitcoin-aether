# Node Identity (generate with scripts/generate_keys.py)
ADDRESS=
PUBLIC_KEY_HEX=
PRIVATE_KEY_HEX=
PRIVATE_KEY_ED25519=

# Quantum Configuration (local mode)
USE_LOCAL_ESTIMATOR=true
USE_SIMULATOR=false
IBM_TOKEN=
IBM_INSTANCE=

# Network
P2P_PORT=4001
RPC_PORT=5000
PEER_SEEDS=[]
ENABLE_RUST_P2P=true
RUST_P2P_PORT=4001
RUST_P2P_GRPC=50051
# Path to Rust binary (relative to project root, or absolute)
# In Docker: /usr/local/bin/qubitcoin-p2p (auto-detected via PATH)
RUST_P2P_BINARY=rust-p2p/target/release/qubitcoin-p2p
RUST_P2P_STARTUP_TIMEOUT=10

# Database
DATABASE_URL=postgresql://root@localhost:26257/qbc?sslmode=disable

# IPFS
IPFS_API=/ip4/127.0.0.1/tcp/5002/http
# Gateway port — use 8081 to avoid conflict with CockroachDB admin UI (8080)
IPFS_GATEWAY_PORT=8081
PINATA_JWT=

# Redis
# REQUIRED: Set a strong Redis password. Used by docker-compose --requirepass.
REDIS_PASSWORD=changeme
REDIS_URL=redis://:${REDIS_PASSWORD}@localhost:6379

# Mining
AUTO_MINE=true
MINING_INTERVAL=10
SNAPSHOT_INTERVAL=100

# LLM / External AI
LLM_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-5-20250929
LOCAL_LLM_URL=
LLM_PRIMARY_ADAPTER=openai
LLM_SEEDER_ENABLED=false
LLM_SEEDER_INTERVAL_BLOCKS=50
LLM_SEEDER_RATE_LIMIT_PER_HOUR=10
LLM_SEEDER_MAX_TOKENS=2048
LLM_SEEDER_COOLDOWN_SECONDS=15

# Gevurah Safety (Aether Tree veto / emergency shutdown authentication)
# REQUIRED for production: shared HMAC secret for veto + shutdown auth.
# Generate with: openssl rand -hex 32
GEVURAH_SECRET=

# Chain
CHAIN_ID=3301
BLOCK_GAS_LIMIT=30000000

# Emission (tail emission fills gap between phi-halving convergence and MAX_SUPPLY)
# TAIL_EMISSION_REWARD=0.1  # QBC/block after phi-halving drops below this value

# Treasury Addresses (REQUIRED before mainnet — fees go here)
# Generate dedicated treasury addresses with: python3 scripts/setup/generate_keys.py
AETHER_FEE_TREASURY_ADDRESS=
CONTRACT_FEE_TREASURY_ADDRESS=

# Aether Tree Fee Economics
AETHER_CHAT_FEE_QBC=0.01
AETHER_CHAT_FEE_USD_TARGET=0.005
AETHER_FEE_PRICING_MODE=qusd_peg
AETHER_FEE_MIN_QBC=0.001
AETHER_FEE_MAX_QBC=1.0
AETHER_FEE_UPDATE_INTERVAL=100
AETHER_QUERY_FEE_MULTIPLIER=2.0
AETHER_FREE_TIER_MESSAGES=5

# Fee Burning (deflationary pressure)
# Percentage of L1 tx fees permanently destroyed (0.0 = none, 1.0 = all)
FEE_BURN_PERCENTAGE=0.5

# Bridge Fees
BRIDGE_FEE_BPS=30  # Basis points (30 = 0.3% fee on cross-chain transfers)

# Bridge & QUSD Treasury Addresses (REQUIRED before bridge deployment — Phase 10)
# These receive the initial 3.3B QUSD allocation and bridge fee revenue.
# Generate dedicated treasury addresses with: python3 scripts/setup/generate_keys.py
BRIDGE_TREASURY_ADDRESS=
QUSD_TREASURY_ADDRESS=

# External Chain RPC URLs (for bridge deployment — Phase 10)
ETH_RPC_URL=
BSC_RPC_URL=
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Bridge operator address on external chains (defaults to deployer if empty)
BRIDGE_OPERATOR_ADDRESS=

# Contract Deployment Fees
CONTRACT_DEPLOY_BASE_FEE_QBC=1.0
CONTRACT_DEPLOY_PER_KB_FEE_QBC=0.1
CONTRACT_DEPLOY_FEE_USD_TARGET=5.0
CONTRACT_FEE_PRICING_MODE=qusd_peg
CONTRACT_EXECUTE_BASE_FEE_QBC=0.01
CONTRACT_TEMPLATE_DISCOUNT=0.5

# Higgs Cognitive Field
HIGGS_FIELD_ADDRESS=
HIGGS_MU=88.45
HIGGS_LAMBDA=0.129
HIGGS_TAN_BETA=1.618033988749895
HIGGS_EXCITATION_THRESHOLD=0.10
HIGGS_DT=0.01
HIGGS_ENABLE_MASS_REBALANCING=true
HIGGS_FIELD_UPDATE_INTERVAL=1

# QUSD Oracle Feeders (used by scripts/deploy/init_oracle_feeders.py)
# Feeder 1 defaults to the node operator ADDRESS if left empty.
# Set Feeder 2 & 3 to trusted oracle addresses (e.g. partner nodes).
ORACLE_FEEDER_2=
ORACLE_FEEDER_3=
# Initial QBC/USD price (8 decimals, e.g. 10000000 = $0.10)
ORACLE_INITIAL_PRICE=10000000
# Staleness threshold in blocks (default: 1000)
ORACLE_MAX_AGE=1000

# ============================================================
# AIKGS (Aether Incentivized Knowledge Growth System)
# ============================================================
# SECURITY [FE-H5]: In production, sensitive secrets (AIKGS_VAULT_MASTER_KEY,
# API_KEY_VAULT_SECRET, etc.) should NOT be passed as environment variables.
# Use a secrets manager instead (HashiCorp Vault, AWS Secrets Manager,
# GCP Secret Manager, etc.).  Environment variables are acceptable for
# development and testing only.
AIKGS_ENABLED=true
AIKGS_USE_RUST_SIDECAR=true
AIKGS_GRPC_ADDR=127.0.0.1
AIKGS_GRPC_PORT=50052
# REQUIRED: Shared secret for gRPC authentication between node and AIKGS sidecar.
# Generate with: openssl rand -hex 32
AIKGS_AUTH_TOKEN=
AIKGS_TREASURY_ADDRESS=
# Maximum single disbursement (QBC). Larger requests are rejected.
AIKGS_MAX_SINGLE_DISBURSEMENT=0.5
# Maximum total daily disbursements (QBC). Rate-limited across all requests.
AIKGS_MAX_DAILY_DISBURSEMENT=500.0
# Maximum number of disbursements per hour (count-based rate limit).
AIKGS_MAX_DISBURSEMENTS_PER_HOUR=100
# Maximum retry attempts for failed disbursements (exponential backoff).
AIKGS_DISBURSE_MAX_RETRIES=3
# Initial backoff delay in milliseconds (doubled on each retry, capped at 60s).
AIKGS_DISBURSE_INITIAL_BACKOFF_MS=1000
AIKGS_BASE_REWARD_QBC=0.05
AIKGS_MAX_REWARD_QBC=0.5
AIKGS_INITIAL_POOL_QBC=1000000.0
AIKGS_EARLY_THRESHOLD=10000
AIKGS_EARLY_MAX_BONUS=2.0
AIKGS_QUALITY_WEIGHT=0.6
AIKGS_NOVELTY_WEIGHT=0.4
AIKGS_L1_COMMISSION_RATE=0.10
AIKGS_L2_COMMISSION_RATE=0.05
AIKGS_MAX_DAILY_SUBMISSIONS=50
# Query limits (AIKGS-H8): default/max page sizes for list endpoints.
AIKGS_QUERY_DEFAULT_LIMIT=50
AIKGS_QUERY_MAX_LIMIT=1000
AIKGS_CURATION_REQUIRED_VOTES=3
AIKGS_DEFAULT_BOUNTY_REWARD=0.25
AIKGS_DEFAULT_BOUNTY_DURATION_DAYS=30
# REQUIRED: Set a strong random secret (min 32 chars). Used to encrypt API keys
# at rest in the AIKGS vault. Generate with: openssl rand -hex 32
API_KEY_VAULT_SECRET=

# AIKGS Contract Addresses (deployed post-genesis)
AIKGS_REWARD_POOL_ADDRESS=
AIKGS_AFFILIATE_REGISTRY_ADDRESS=
AIKGS_CONTRIBUTION_LEDGER_ADDRESS=
AIKGS_BOUNTY_CONTRACT_ADDRESS=
AIKGS_NFT_CONTRACT_ADDRESS=

# ============================================================
# Telegram Bot (@AetherTreeBot)
# ============================================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=AetherTreeBot
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_MINI_APP_URL=https://qbc.network/twa
TELEGRAM_WEBHOOK_URL=

# LLM Adapters (for AIKGS shared key pool)
GROK_API_KEY=
GROK_MODEL=grok-3
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-large-latest

# ============================================================
# Dilithium Security Level (ML-DSA)
# ============================================================
# 2 = ML-DSA-44 (128-bit classical, NIST Level 2)
# 3 = ML-DSA-65 (192-bit classical, NIST Level 3)
# 5 = ML-DSA-87 (256-bit classical, NIST Level 5) — RECOMMENDED
DILITHIUM_SECURITY_LEVEL=5

# ============================================================
# Transaction Reversibility (opt-in)
# ============================================================
# Default reversal window in blocks (0 = irreversible by default)
REVERSAL_DEFAULT_WINDOW=0
# Maximum allowed reversal window (~24h at 3.3s/block)
REVERSAL_MAX_WINDOW=26182
# Guardian approvals needed for third-party reversal
REVERSAL_GUARDIAN_THRESHOLD=2

# ============================================================
# Substrate Hybrid Mode
# ============================================================
# Set SUBSTRATE_MODE=true to run Python as execution service
# alongside a Substrate consensus node.
SUBSTRATE_MODE=false
SUBSTRATE_WS_URL=ws://localhost:9944
SUBSTRATE_HTTP_URL=http://localhost:9944
SUBSTRATE_SUDO_SEED=//Alice

# ============================================================
# Infrastructure (Docker Compose)
# ============================================================
# REQUIRED: Grafana admin password. No default — must be set explicitly.
GRAFANA_ADMIN_PASSWORD=

# Debugging
DEBUG=true
