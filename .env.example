# Node Identity (generate with scripts/generate_keys.py)
ADDRESS=
PUBLIC_KEY_HEX=
PRIVATE_KEY_HEX=
PRIVATE_KEY_ED25519=

# Quantum Configuration (local mode)
USE_LOCAL_ESTIMATOR=true
USE_SIMULATOR=false
IBM_TOKEN=
IBM_INSTANCE=

# Network
P2P_PORT=4001
RPC_PORT=5000
PEER_SEEDS=[]
ENABLE_RUST_P2P=true
RUST_P2P_PORT=4001
RUST_P2P_GRPC=50051
# Path to Rust binary (relative to project root, or absolute)
# In Docker: /usr/local/bin/qubitcoin-p2p (auto-detected via PATH)
RUST_P2P_BINARY=rust-p2p/target/release/qubitcoin-p2p
RUST_P2P_STARTUP_TIMEOUT=10

# Database
DATABASE_URL=postgresql://root@localhost:26257/qbc?sslmode=disable

# IPFS
IPFS_API=/ip4/127.0.0.1/tcp/5002/http
# Gateway port — use 8081 to avoid conflict with CockroachDB admin UI (8080)
IPFS_GATEWAY_PORT=8081
PINATA_JWT=

# Redis
REDIS_URL=redis://:qbc_redis_pass_change_in_prod@localhost:6379

# Mining
AUTO_MINE=true
MINING_INTERVAL=10
SNAPSHOT_INTERVAL=100

# LLM / External AI
LLM_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-5-20250929
LOCAL_LLM_URL=
LLM_PRIMARY_ADAPTER=openai
LLM_SEEDER_ENABLED=false
LLM_SEEDER_INTERVAL_BLOCKS=50
LLM_SEEDER_RATE_LIMIT_PER_HOUR=10
LLM_SEEDER_MAX_TOKENS=2048
LLM_SEEDER_COOLDOWN_SECONDS=15

# Chain
CHAIN_ID=3301
BLOCK_GAS_LIMIT=30000000

# Treasury Addresses (REQUIRED before mainnet — fees go here)
# Generate dedicated treasury addresses with: python3 scripts/setup/generate_keys.py
AETHER_FEE_TREASURY_ADDRESS=
CONTRACT_FEE_TREASURY_ADDRESS=

# Aether Tree Fee Economics
AETHER_CHAT_FEE_QBC=0.01
AETHER_CHAT_FEE_USD_TARGET=0.005
AETHER_FEE_PRICING_MODE=qusd_peg
AETHER_FEE_MIN_QBC=0.001
AETHER_FEE_MAX_QBC=1.0
AETHER_FEE_UPDATE_INTERVAL=100
AETHER_QUERY_FEE_MULTIPLIER=2.0
AETHER_FREE_TIER_MESSAGES=5

# Bridge Fees
BRIDGE_FEE_BPS=30  # Basis points (30 = 0.3% fee on cross-chain transfers)

# Contract Deployment Fees
CONTRACT_DEPLOY_BASE_FEE_QBC=1.0
CONTRACT_DEPLOY_PER_KB_FEE_QBC=0.1
CONTRACT_DEPLOY_FEE_USD_TARGET=5.0
CONTRACT_FEE_PRICING_MODE=qusd_peg
CONTRACT_EXECUTE_BASE_FEE_QBC=0.01
CONTRACT_TEMPLATE_DISCOUNT=0.5

# Debugging
DEBUG=true
