# secure_key.env — Qubitcoin Node Key Material
# ============================================
# AUTO-GENERATED by: python3 scripts/setup/generate_keys.py
# NEVER commit this file to version control!
# This file is listed in .gitignore.
#
# Contains ONLY cryptographic identity — no node config.
# Node configuration goes in .env (see .env.example).

# Security level: 2=ML-DSA-44, 3=ML-DSA-65, 5=ML-DSA-87 (default)
DILITHIUM_LEVEL=5

# Post-quantum address (SHA-256 derived from public key)
ADDRESS=

# Public key (hex-encoded)
PUBLIC_KEY_HEX=

# Private key (hex-encoded) — KEEP SECRET
PRIVATE_KEY_HEX=

# Human-readable address alias (e.g., "tiger-ocean-marble")
CHECK_PHRASE=

# SHA-256 hash of recovery mnemonic (for verification only)
# The mnemonic itself is shown ONCE during generation — write it down!
MNEMONIC_HASH=

# ============================================================
# External Chain Deployer Keys (for bridge deployment — Phase 10)
# ============================================================
# Ethereum-compatible private key (secp256k1) for deploying wQBC/wQUSD.
# Same key works for ETH, BSC, Polygon, etc. (all EVM chains share key format).
# Format: 0x-prefixed 64-character hex string
# Generate with any Ethereum wallet (MetaMask export, etc.)
ETH_DEPLOYER_PRIVATE_KEY=

# Solana keypair file path (JSON array format from solana-keygen)
# Generate with: solana-keygen new --outfile ~/.config/solana/bridge-deployer.json
SOLANA_DEPLOYER_KEYPAIR_PATH=
