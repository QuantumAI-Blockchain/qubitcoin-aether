# Exclude data directories
data/
certs/
my-safe-directory/

# Exclude Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
*.egg
*.egg-info/
dist/
build/
*.whl

# Exclude git
.git/
.gitignore

# Exclude logs
logs/
*.log

# Exclude environment
venv/
.env.example

# Exclude deployment files (we only need src/)
deployment/
scripts/
docs/
tests/

# Exclude Rust build artifacts (compiled inside Docker)
rust-p2p/target/
aether-core/target/

# Exclude frontend (not part of backend container)
frontend/node_modules/

# Exclude Claude/IDE artifacts
.claude/
