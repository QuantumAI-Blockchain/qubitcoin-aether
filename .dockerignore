# Exclude data directories
data/
certs/
my-safe-directory/

# Exclude Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
*.egg
*.egg-info/
dist/
build/
*.whl

# Exclude git
.git/
.gitignore

# Exclude logs
logs/
*.log

# Exclude environment
venv/
.env.example

# Exclude deployment files (we only need src/)
deployment/
scripts/
docs/
tests/
